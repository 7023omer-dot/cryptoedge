{
  "rewrites": [
    { "source": "/((?!.*\\.(?:webp|png|jpg|jpeg|gif|svg|ico|js|css|json|woff2?|ttf)).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
